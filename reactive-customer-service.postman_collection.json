{
  "info": {
    "name": "Reactive Customer Service API",
    "_postman_id": "3e66f4b2-9d57-4fd8-a6e3-c1dc3f2e6a10",
    "description": "Colección para probar la API REST reactiva de Customer Service (Spring Boot WebFlux). Base path: /api/v1/customers",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "customerId",
      "value": "",
      "type": "string",
      "description": "Se establece automáticamente al crear un cliente"
    }
  ],
  "item": [
    {
      "name": "Customers",
      "item": [
        {
          "name": "POST Crear cliente — 201 Created",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 Created', () => pm.response.to.have.status(201));",
                  "pm.test('Response tiene id generado', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.id).to.be.a('number');",
                  "    pm.collectionVariables.set('customerId', body.id);",
                  "});",
                  "pm.test('Campos de respuesta son correctos', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.nombre).to.eql('Alex');",
                  "    pm.expect(body.apellido).to.eql('Prieto');",
                  "    pm.expect(body.estado).to.eql('ACTIVE');",
                  "    pm.expect(body.edad).to.eql(30);",
                  "});",
                  "pm.test('Content-Type es application/json', () => {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Alex\",\n  \"apellido\": \"Prieto\",\n  \"estado\": \"ACTIVE\",\n  \"edad\": 30\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/customers",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "customers"]
            },
            "description": "Crea un nuevo cliente con ID autogenerado. Guarda el ID en la variable `customerId` para los siguientes requests."
          },
          "response": []
        },
        {
          "name": "POST Crear cliente con ID explícito — 201 Created",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 Created', () => pm.response.to.have.status(201));",
                  "pm.test('ID en respuesta es el enviado', () => {",
                  "    pm.expect(pm.response.json().id).to.eql(100);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": 100,\n  \"nombre\": \"Juan\",\n  \"apellido\": \"García\",\n  \"estado\": \"INACTIVE\",\n  \"edad\": 45\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/customers",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "customers"]
            },
            "description": "Crea un cliente proporcionando un ID explícito."
          },
          "response": []
        },
        {
          "name": "POST Crear cliente — 409 ID Duplicado",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 409 Conflict', () => pm.response.to.have.status(409));",
                  "pm.test('Body contiene status 409', () => {",
                  "    pm.expect(pm.response.json().status).to.eql(409);",
                  "});",
                  "pm.test('Body contiene mensaje de error', () => {",
                  "    pm.expect(pm.response.json().mensaje).to.be.a('string').and.not.empty;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": 100,\n  \"nombre\": \"Duplicado\",\n  \"apellido\": \"Conflicto\",\n  \"estado\": \"ACTIVE\",\n  \"edad\": 25\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/customers",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "customers"]
            },
            "description": "Intenta crear un cliente con un ID ya existente. Requiere haber ejecutado 'POST con ID explícito' antes."
          },
          "response": []
        },
        {
          "name": "POST Crear cliente — 400 Validación de campos",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400 Bad Request', () => pm.response.to.have.status(400));",
                  "pm.test('Body contiene array de errores', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.status).to.eql(400);",
                  "    pm.expect(body.errores).to.be.an('array').and.not.empty;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"\",\n  \"apellido\": \"\",\n  \"estado\": \"INVALIDO\",\n  \"edad\": -1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/customers",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "customers"]
            },
            "description": "Envía datos inválidos para verificar la validación de Bean Validation."
          },
          "response": []
        },
        {
          "name": "GET Listar clientes activos — 200 OK",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Response es un array', () => {",
                  "    pm.expect(pm.response.json()).to.be.an('array');",
                  "});",
                  "pm.test('Todos los clientes son ACTIVE', () => {",
                  "    pm.response.json().forEach(c => pm.expect(c.estado).to.eql('ACTIVE'));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/customers/active",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "customers", "active"]
            },
            "description": "Retorna todos los clientes con estado ACTIVE."
          },
          "response": []
        },
        {
          "name": "GET Buscar cliente por ID — 200 OK",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('ID de respuesta coincide con el buscado', () => {",
                  "    const id = parseInt(pm.collectionVariables.get('customerId'));",
                  "    pm.expect(pm.response.json().id).to.eql(id);",
                  "});",
                  "pm.test('Response tiene todos los campos esperados', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.all.keys('id', 'nombre', 'apellido', 'estado', 'edad');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/customers/{{customerId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "customers", "{{customerId}}"]
            },
            "description": "Busca el cliente cuyo ID fue guardado por 'POST Crear cliente'. Requiere ejecutar ese request antes."
          },
          "response": []
        },
        {
          "name": "GET Buscar cliente por ID — 404 Not Found",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404 Not Found', () => pm.response.to.have.status(404));",
                  "pm.test('Body contiene status 404', () => {",
                  "    pm.expect(pm.response.json().status).to.eql(404);",
                  "});",
                  "pm.test('Body contiene mensaje de error', () => {",
                  "    pm.expect(pm.response.json().mensaje).to.be.a('string').and.not.empty;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/customers/99999",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "customers", "99999"]
            },
            "description": "Intenta buscar un cliente inexistente. Retorna 404 Not Found."
          },
          "response": []
        }
      ]
    },
