        {
          "name": "GET Listar clientes activos — 200 OK (paginado)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Response tiene estructura de página', () => {",
                  "    pm.expect(body).to.have.property('content').that.is.an('array');",
                  "    pm.expect(body).to.have.property('page').that.is.a('number');",
                  "    pm.expect(body).to.have.property('size').that.is.a('number');",
                  "    pm.expect(body).to.have.property('totalElements').that.is.a('number');",
                  "    pm.expect(body).to.have.property('totalPages').that.is.a('number');",
                  "    pm.expect(body).to.have.property('last').that.is.a('boolean');",
                  "});",
                  "pm.test('Todos los clientes en content son ACTIVE', () => {",
                  "    body.content.forEach(c => pm.expect(c.estado).to.eql('ACTIVE'));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/customers/active?page=0&size=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "customers", "active"],
              "query": [
                { "key": "page", "value": "0", "description": "Página (0-based)" },
