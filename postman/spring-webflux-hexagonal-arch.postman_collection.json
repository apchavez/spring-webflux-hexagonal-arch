    "description": "Colección para probar la API REST reactiva de Customer Service (Spring Boot WebFlux). Base path: /api/v1/customers\n\nUsar junto con uno de los environments incluidos en postman/:\n- spring-webflux-hexagonal-arch.local.postman_environment.json  → local (H2)\n- spring-webflux-hexagonal-arch.k8s.postman_environment.json    → Kubernetes (PostgreSQL)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{adminToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "customerId",
      "value": "",
      "type": "string",
      "description": "Se establece automáticamente al crear un cliente (POST sin id explícito)"
    },
    {
      "key": "adminToken",
      "value": "",
      "type": "string",
      "description": "JWT RS256 con ROLE_ADMIN. Generar con JwtService.generateToken(\"test\", \"ADMIN\") y pegar aquí o en el environment."
    }
  ],
  "item": [
    {
      "name": "Customers",
      "item": [
        {
          "name": "POST Crear cliente — 201 Created",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 Created', () => pm.response.to.have.status(201));",
                  "pm.test('Response tiene id generado', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.id).to.be.a('number');",
                  "    pm.collectionVariables.set('customerId', body.id);",
                  "});",
                  "pm.test('Campos de respuesta son correctos', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.nombre).to.eql('Alex');",
                  "    pm.expect(body.apellido).to.eql('Prieto');",
                  "    pm.expect(body.estado).to.eql('ACTIVE');",
                  "    pm.expect(body.edad).to.eql(30);",
                  "});",
                  "pm.test('Content-Type es application/json', () => {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Alex\",\n  \"apellido\": \"Prieto\",\n  \"estado\": \"ACTIVE\",\n  \"edad\": 30\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/customers",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "customers"]
            },
            "description": "Crea un nuevo cliente con ID autogenerado. Guarda el ID en la variable `customerId` para los siguientes requests."
          },
          "response": []
        },
